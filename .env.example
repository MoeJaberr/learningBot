# Copy this file to .env and fill in your values.
# Never commit the real .env file.

# Required: used for all AI features (summarize, notes, flashcards, tutor)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Required: used only for audio transcription (Whisper)
OPENAI_API_KEY=your_openai_api_key_here

# Path to your Obsidian vault — notes are saved to Lectures/ inside it
OBSIDIAN_VAULT_PATH=C:\Users\moe\Obsidian
